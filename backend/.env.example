# Copy this file to .env and fill in your values

# PostgreSQL - replace 'yourpassword' with the password you set for bsquare_user in pgAdmin
DATABASE_URL=postgresql://bsquare_user:yourpassword@localhost:5432/bsquare

# JWT Secrets - these can be any random strings, keep them secret
JWT_SECRET=bsquare_jwt_secret_key_2024_secure_xyz
JWT_REFRESH_SECRET=bsquare_refresh_secret_key_2024_abc
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Anthropic API Key - get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=5000
NODE_ENV=development

# Frontend URL
CLIENT_URL=http://localhost:3000
